rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      // Owners may edit their own profile fields and set their role exactly
      // once during onboarding (null -> student/founder), but can't touch
      // their own status (suspend/reactivate) or self-promote to admin —
      // only an admin can do either.
      allow update: if isSignedIn() && (
        (isOwner(userId) &&
          request.resource.data.status == resource.data.status &&
          (request.resource.data.role == resource.data.role ||
            (resource.data.role == null && request.resource.data.role in ['student', 'founder']))
        ) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /startups/{startupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.founderId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.founderId == request.auth.uid || isAdmin());
    }

    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.founderId == request.auth.uid &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.verificationStatus == 'approved';
      allow update, delete: if isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.founderId == request.auth.uid;
    }

    match /applications/{applicationId} {
      function isApplicant() {
        return resource.data.studentId == request.auth.uid;
      }
      function isOwnerFounder() {
        return get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.founderId == request.auth.uid;
      }

      allow read: if isSignedIn() && (isApplicant() || isOwnerFounder());
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (
        (isApplicant() && request.resource.data.status == resource.data.status) ||
        (isOwnerFounder() &&
          request.resource.data.studentId == resource.data.studentId &&
          request.resource.data.coverNote == resource.data.coverNote &&
          request.resource.data.cvUrl == resource.data.cvUrl &&
          request.resource.data.portfolioLink == resource.data.portfolioLink)
      );
    }

    match /bookmarks/{bookmarkId} {
      allow read, write: if isSignedIn() && resource.data.studentId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    match /messages/{conversationId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;

      match /thread/{messageId} {
        function isConversationParticipant() {
          return request.auth.uid in
            get(/databases/$(database)/documents/messages/$(conversationId)).data.participantIds;
        }

        allow read: if isSignedIn() && isConversationParticipant();
        allow create: if isSignedIn() && isConversationParticipant() &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
